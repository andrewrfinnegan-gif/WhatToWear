# Copy to .env to connect the app to the WhatToWear backend (see server/).
#
# The backend provides accounts, cloud closet sync, and the Claude AI stylist.
# The Anthropic API key lives ONLY on the server — it is never in this app.
#
# Without an API URL the app runs fully offline: local-only closet and the
# on-device rules engine for outfit suggestions.

# Web / iOS simulator / Android emulator (use 10.0.2.2 for Android emulator):
EXPO_PUBLIC_API_URL=http://localhost:4000

# Physical phone on the same Wi-Fi: use your machine's LAN IP, e.g.
# EXPO_PUBLIC_API_URL=http://192.168.1.50:4000

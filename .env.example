# Copy to .env to enable the Claude-powered auto-tagging and AI stylist.
# Without these the app runs fully on the on-device rules engine.
#
# SECURITY: an EXPO_PUBLIC_ var is embedded in the client bundle. This is fine
# for local development, but for a shipped app route requests through a backend
# proxy (set EXPO_PUBLIC_ANTHROPIC_PROXY_URL) so the key never ships to devices.

EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Optional: send Claude requests through your own proxy instead of api.anthropic.com.
# EXPO_PUBLIC_ANTHROPIC_PROXY_URL=https://your-proxy.example.com/v1/messages

# Optional model overrides.
# EXPO_PUBLIC_TAGGING_MODEL=claude-haiku-4-5
# EXPO_PUBLIC_STYLING_MODEL=claude-sonnet-4-6

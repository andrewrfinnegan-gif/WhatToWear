# Copy to server/.env and fill in.

# Port the API listens on.
PORT=4000

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# How long issued access tokens stay valid.
JWT_EXPIRES_IN=30d

# Anthropic API key. Lives ONLY on the server — never shipped to clients.
# When unset, the /ai/* endpoints return 503 and the app falls back to its
# on-device rules engine.
ANTHROPIC_API_KEY=

# Models used by the AI proxy.
TAGGING_MODEL=claude-haiku-4-5
STYLING_MODEL=claude-sonnet-4-6

# Path to the SQLite database file (created on first run).
DB_PATH=./whattowear.db

# Comma-separated list of allowed CORS origins. Use * for any (dev only).
CORS_ORIGIN=*

# --- Purchase integration -------------------------------------------------

# Shared secret the inbound-email webhook requires (header x-webhook-secret).
# Generate a long random value. Leave blank to disable the webhook.
WEBHOOK_SECRET=

# Domain users forward receipts to. Configure your email provider's inbound
# parse to POST messages for *@INGEST_DOMAIN to /webhooks/email. The app shows
# each user their address: <alias>@INGEST_DOMAIN
INGEST_DOMAIN=

# Public URL of THIS API (used to build the Gmail OAuth redirect), e.g.
# https://api.whattowear.app
PUBLIC_BASE_URL=

# Deep link back into the app after Gmail OAuth completes.
APP_REDIRECT=whattowear://account

# Gmail OAuth (optional). Create credentials in Google Cloud Console with the
# gmail.readonly scope and redirect URI <PUBLIC_BASE_URL>/integrations/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
